{
  "ConnectionStrings": {
    "AuthDatabase": ""
  },
  "Jwt": {
    "Issuer": "https://api.kuva.com.br/auth",
    "Audience": "kuva-api",
    "AccessTokenMinutes": 15,
    "KeyId": "kuva-auth-2026-01",
    "PrivateKeySecretName": "Jwt--PrivateKeyPem"
  },
  "RefreshToken": {
    "ConsumerExpirationDays": 30,
    "MerchantExpirationHours": 12,
    "TokenBytes": 64
  },
  "PasswordPolicy": {
    "MinimumLength": 10,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true
  },
  "KeyVault": {
    "Uri": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Metrics": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
