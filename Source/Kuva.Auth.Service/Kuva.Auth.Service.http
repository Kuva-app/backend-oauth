@Kuva.Auth.Service_HostAddress = http://localhost:8081

POST {{Kuva.Auth.Service_HostAddress}}/api/v1/auth/register
Content-Type: application/json

{
  "name": "Cliente Kuva",
  "email": "cliente@email.com",
  "phone": "+5511999999999",
  "password": "SenhaSegura@123",
  "acceptedTermsVersion": "1.0",
  "acceptedPrivacyPolicyVersion": "1.0",
  "photoProcessingConsent": true
}

###

POST {{Kuva.Auth.Service_HostAddress}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "cliente@email.com",
  "password": "SenhaSegura@123"
}

